# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
# URL for BetterAuth callbacks and redirects (same as app URL)
BETTER_AUTH_URL=http://localhost:3000
# URL where the Next.js app is running (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Analytics & Tag Manager ────────────────────────────────────────────
# GTM container ID (get from tagmanager.google.com)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# GA4 Measurement ID (get from GA4 → Admin → Data Streams)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Sanity CMS (blog) ─────────────────────────────────────────────────────────
# Project settings → API. Studio is mounted at /content-studio
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Write token (Project → API → Tokens, Editor role) — only needed to run the blog seed script
SANITY_API_WRITE_TOKEN=your-write-token
# Webhook secret for on-demand revalidation (Sanity → API → Webhooks)
SANITY_REVALIDATE_SECRET=your-random-secret

# ── Google OAuth (BetterAuth social provider) ─────────────────────────────────
# Get from: console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── LLM (OpenRouter → DeepSeek V4 Flash) ─────────────────────────────────────
# Get from: openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# Change this env var to switch the default model globally (no code change needed)
LITELLM_DEFAULT_MODEL=deepseek/deepseek-v4-flash

# ── Redis Rate Limiting (Upstash) ─────────────────────────────────────────────
# Get from: console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ── Email (Resend — auth, invites, critical) ──────────────────────────────────
# Get from: resend.com → API Keys · Free: 3,000/month · 100/day
RESEND_API_KEY=re_xxx
# Verified sender in Resend dashboard — must match a verified domain/address
# Used for: welcome, password reset, client invite, handoff, credit grace
RESEND_FROM_EMAIL=Octively <noreply@octively.com>

# ── Email (Brevo — digest, usage nudges, marketing) ───────────────────────────
# Get from: app.brevo.com → Settings → SMTP & API → API Keys
# Free: 9,000/month · 300/day
BREVO_API_KEY=xkeysib-xxx
# Verified senders in Brevo dashboard → Senders & Domains
# Used for: usage warnings, onboarding nudges
BREVO_FROM_EMAIL=noreply@octively.com
# Used for: weekly digest emails only
BREVO_DIGEST_EMAIL=digest@octively.com

# ── Portal URL (for invitation links) ────────────────────────────────────────
# In production: https://app.octively.com — In local dev: http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# ── Phase 2: Platform Admin ───────────────────────────────────────────────────
# Email address that has access to /dashboard/admin/platform (owner only)
PLATFORM_OWNER_EMAIL=your@email.com

# ── WhatsApp (billing upgrade / top-up contact) ───────────────────────────────
# International format, no + prefix, no spaces (e.g. 923001234567 for +92 300 1234567)
# Used by billing page upgrade buttons; set in Vercel env vars for production
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# ── Phase 2: Cron Jobs ────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Add to Vercel: Settings → Environment Variables
CRON_SECRET=your-cron-secret-here

# Kill switch for /api/internal/migrate (DDL-executing endpoint).
# Leave unset/false in normal operation; set to "true" only for a one-shot
# migration run, then unset again. While disabled the endpoint returns 404.
MIGRATIONS_ENABLED=false

# ── Phase 2: PayFast (PKR payments) ──────────────────────────────────────────
# Get from: payfast.co.za → Merchant Settings
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
# REQUIRED for live payments — the ITN webhook fails closed (rejects all
# callbacks) if this is unset, since the signature is forgeable without it.
PAYFAST_PASSPHRASE=your-passphrase

# ── Phase 3: Cloudflare R2 (document/file storage) ───────────────────────────
# Get from: dash.cloudflare.com → R2 → Manage R2 API Tokens
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=octively-documents

# ── Phase 3: Upstash QStash (background job queue) ────────────────────────────
# Get from: console.upstash.com → QStash → Dashboard
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# ── BYOK: LLM key encryption (AES-GCM, 32-char key) ─────────────────────────
# Generate: openssl rand -base64 32
# Required if any org stores their own LLM API key via Settings → BYOK
LLM_KEY_ENCRYPTION_SECRET=your-32-char-secret-here

# ── Phase 3: Jina AI (embeddings for RAG) ────────────────────────────────────
# Get from: jina.ai → API → Get API Key (free tier: 1M tokens/month, no CC needed)
JINA_API_KEY=jina_xxx

# ── Phase 3: Firecrawl (URL → Markdown crawling) ─────────────────────────────
# Get from: firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=fc-xxx

# ── Tavily (URL extraction for the public Website Readiness Checker tool) ─────
# Get from: app.tavily.com → API Keys. Generous free tier; basic extract costs
# 1 credit per 5 URLs. Used by /tools/website-chatbot-readiness-checker only.
# If unset, the readiness checker returns "temporarily unavailable".
TAVILY_API_KEY=tvly-xxx

# ── Lead Webhooks (outbound, per-bot) ────────────────────────────────────────
# Signs every outbound lead webhook with HMAC-SHA256 so receivers can verify it
# came from OwFlex. Set in Vercel env vars → applied to all bots on the account.
#
# Generate (pick any one):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   openssl rand -hex 32
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Verify on the receiver side (Node.js example):
#   const sig = createHmac('sha256', process.env.WEBHOOK_SIGNING_SECRET).update(rawBody).digest('hex')
#   const match = `sha256=${sig}` === req.headers['x-owflex-signature']
WEBHOOK_SIGNING_SECRET=your-64-char-hex-secret-here

# ── Phase 2: Lemon Squeezy (USD payments) ────────────────────────────────────
# Get from: app.lemonsqueezy.com → Settings → API → Webhooks
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMON_SQUEEZY_STORE_ID=your-store-id
# Variant IDs from LS dashboard (Products → Variants)
LS_VARIANT_STARTER=your-starter-variant-id
LS_VARIANT_GROWTH=your-growth-variant-id
LS_VARIANT_PRO=your-pro-variant-id

# Lemon Squeezy — Plan subscription variant IDs (monthly, 5/9/9)
LS_VARIANT_PLAN_STARTER=your-starter-plan-variant-id
LS_VARIANT_PLAN_PRO=your-pro-plan-variant-id
LS_VARIANT_PLAN_AGENCY=your-agency-plan-variant-id

# Demo seed account passwords (scripts/seed-demo.ts) — never commit real values
DEMO_DEV_PASSWORD=change-me
DEMO_CLIENT_PASSWORD=change-me
