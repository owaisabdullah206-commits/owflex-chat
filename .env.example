# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
# URL for BetterAuth callbacks and redirects (same as app URL)
BETTER_AUTH_URL=http://localhost:3000
# URL where the Next.js app is running (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google OAuth (BetterAuth social provider) ─────────────────────────────────
# Get from: console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── LLM (OpenRouter → DeepSeek V4 Flash) ─────────────────────────────────────
# Get from: openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# Change this env var to switch the default model globally (no code change needed)
LITELLM_DEFAULT_MODEL=deepseek/deepseek-v4-flash

# ── Redis Rate Limiting (Upstash) ─────────────────────────────────────────────
# Get from: console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxx

# ── Portal URL (for invitation links) ────────────────────────────────────────
# In production: https://app.owflex.com — In local dev: http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# ── Phase 2: Platform Admin ───────────────────────────────────────────────────
# Email address that has access to /dashboard/admin/platform (owner only)
PLATFORM_OWNER_EMAIL=your@email.com

# ── Phase 2: Cron Jobs ────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Add to Vercel: Settings → Environment Variables
CRON_SECRET=your-cron-secret-here

# ── Phase 2: PayFast (PKR payments) ──────────────────────────────────────────
# Get from: payfast.co.za → Merchant Settings
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# ── Phase 3: Cloudflare R2 (document/file storage) ───────────────────────────
# Get from: dash.cloudflare.com → R2 → Manage R2 API Tokens
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=owflex-documents

# ── Phase 3: Upstash QStash (background job queue) ────────────────────────────
# Get from: console.upstash.com → QStash → Dashboard
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# ── Phase 3: Jina AI (embeddings for RAG) ────────────────────────────────────
# Get from: jina.ai → API → Get API Key (free tier: 1M tokens/month, no CC needed)
JINA_API_KEY=jina_xxx

# ── Phase 3: Firecrawl (URL → Markdown crawling) ─────────────────────────────
# Get from: firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=fc-xxx

# ── Phase 2: Lemon Squeezy (USD payments) ────────────────────────────────────
# Get from: app.lemonsqueezy.com → Settings → API → Webhooks
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMON_SQUEEZY_STORE_ID=your-store-id
# Variant IDs from LS dashboard (Products → Variants)
LS_VARIANT_STARTER=your-starter-variant-id
LS_VARIANT_GROWTH=your-growth-variant-id
LS_VARIANT_PRO=your-pro-variant-id
